rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Public event cover images (read-only for the world)
    match /events/{eventId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && exists(/databases/(default)/documents/users/$(request.auth.uid))
                   && get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ["organizer", "admin"]
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches("image/.*");
    }

    // User avatars — only the user can write, everyone can read
    match /avatars/{uid}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 2 * 1024 * 1024
                   && request.resource.contentType.matches("image/.*");
    }
  }
}
