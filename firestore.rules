rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- helpers ----------
    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    function isOrganizer() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ["organizer", "admin"];
    }

    // ---------- users ----------
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid)
                    && request.resource.data.uid == uid
                    && request.resource.data.role in ["member", null];
      // Users can update their own profile but cannot elevate their own role.
      allow update: if isSelf(uid)
                    && (!("role" in request.resource.data.diff(resource.data).affectedKeys())
                        || isAdmin());
      allow delete: if isAdmin();
    }

    // ---------- events ----------
    match /events/{eventId} {
      allow read: if true; // public event listing
      allow create, update, delete: if isOrganizer();
      // enrolledCount is bumped through a transaction from clients when they RSVP.
      // Restrict updates from non-organizers to only that field.
      allow update: if isSignedIn()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["enrolledCount"]);
    }

    // ---------- rsvps ----------
    match /rsvps/{rsvpId} {
      allow read: if isSignedIn()
                  && (resource.data.uid == request.auth.uid || isOrganizer());
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && rsvpId == request.resource.data.eventId + "_" + request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn()
                    && (resource.data.uid == request.auth.uid || isOrganizer());
    }

    // ---------- feed posts ----------
    match /posts/{postId} {
      allow read: if true;
      allow create: if isSignedIn()
                    && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if isSignedIn()
                            && (resource.data.authorUid == request.auth.uid || isOrganizer());
    }
  }
}
